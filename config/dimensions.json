      "prompts/daily_analysis_report.md 的 {{CATEGORY_LIST_PSY/META/PHY}} 占位符（description 字段）",
      "scripts/dimension_usage.py 的 CATEGORIES / KEYWORDS（name + keywords 字段）"
    ],
    "maintenance_notes": [
      "description 给模型阅读用，简短的中文破折号解释",
      "keywords 给老报告关键词回填用，命中任何一个即归入该大类",
      "新增大类时：同时填 description + keywords；keywords 至少包含大类名本身",
      "重命名大类会使旧 index 里该大类对不上，需要连带迁移 dimension_usage_index.json"
    ]
  },
